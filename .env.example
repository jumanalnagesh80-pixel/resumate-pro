# Copy this file to .env and fill in your values

# Required: Change this to a long random secret in production!
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Optional: Enable GPT-powered AI features
OPENAI_API_KEY=

# Optional: Override SQLite with PostgreSQL
# DATABASE_URL=postgresql+psycopg://user:pass@localhost/resumate

# Optional: Restrict CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://yourdomain.com

# Optional: Change JWT expiry (default: 24 hours)
# JWT_EXPIRE_HOURS=24

# Optional: Server port (default: 8000)
# PORT=8000
